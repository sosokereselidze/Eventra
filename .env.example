# Node.js API base URL (frontend)
VITE_API_URL=http://localhost:3001

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/eventflow

# Optional: JWT secret for the API (server). Defaults to a dev value if unset.
# JWT_SECRET=your-secret-in-production

# Google Authentication
# Create credentials here: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
VITE_GOOGLE_CLIENT_ID=your-google-client-id

# Server Base URL (optional, for absolute upload paths)
# BASE_URL=https://your-api-domain.com

# Admin initial password
# ADMIN_PASSWORD=your-secure-admin-password
